import 'package:injectable/injectable.dart';

import '../../../../core/utils/either.dart';
import '../../domain/entities/dashboard_entity.dart';
import '../../domain/failures/dashboard_failure.dart';
import '../../domain/repositories/dashboard_repository.dart';
import '../../domain/value_objects/user_role.dart';
import '../datasources/dashboard_local_datasource.dart';
import '../datasources/dashboard_remote_datasource.dart';
import '../models/dashboard_dto.dart';

/// Implementation of dashboard repository
///
/// This repository coordinates between remote API calls and local caching
/// to provide efficient and reliable dashboard data access.
@Injectable(as: DashboardRepository)
class DashboardRepositoryImpl implements DashboardRepository {
  final IDashboardRemoteDataSource _remoteDataSource;
  final IDashboardLocalDataSource _localDataSource;

  const DashboardRepositoryImpl(this._remoteDataSource, this._localDataSource);

  @override
  Future<Either<DashboardFailure, StudentDashboardEntity>> getStudentDashboard(
    String studentId,
  ) async {
    try {
      // Check cache first
      final cachedDashboard = await _localDataSource.getCachedStudentDashboard(
        studentId,
      );
      final isCacheValid = await _localDataSource.isCacheValid(
        studentId,
        'student',
      );

      if (cachedDashboard != null && isCacheValid) {
        return Right(cachedDashboard.toDomain());
      }

      // Fetch from remote if cache is invalid or missing
      final remoteDashboard = await _remoteDataSource.getStudentDashboard(
        studentId,
      );

      // Cache the fresh data
      await _localDataSource.cacheStudentDashboard(studentId, remoteDashboard);

      return Right(remoteDashboard.toDomain());
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get student dashboard: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, StudentDashboardEntity>>
  getStudentDashboardByDateRange(
    String studentId,
    DateTime startDate,
    DateTime endDate,
  ) async {
    try {
      final remoteDashboard = await _remoteDataSource
          .getStudentDashboardByDateRange(studentId, startDate, endDate);

      return Right(remoteDashboard.toDomain());
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get student dashboard by date range: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, TutorDashboardEntity>> getTutorDashboard(
    String tutorId,
  ) async {
    try {
      // Check cache first
      final cachedDashboard = await _localDataSource.getCachedTutorDashboard(
        tutorId,
      );
      final isCacheValid = await _localDataSource.isCacheValid(
        tutorId,
        'tutor',
      );

      if (cachedDashboard != null && isCacheValid) {
        return Right(cachedDashboard.toDomain());
      }

      // Fetch from remote if cache is invalid or missing
      final remoteDashboard = await _remoteDataSource.getTutorDashboard(
        tutorId,
      );

      // Cache the fresh data
      await _localDataSource.cacheTutorDashboard(tutorId, remoteDashboard);

      return Right(remoteDashboard.toDomain());
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get tutor dashboard: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, TutorDashboardEntity>>
  getTutorDashboardByDateRange(
    String tutorId,
    DateTime startDate,
    DateTime endDate,
  ) async {
    try {
      final remoteDashboard = await _remoteDataSource
          .getTutorDashboardByDateRange(tutorId, startDate, endDate);

      return Right(remoteDashboard.toDomain());
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get tutor dashboard by date range: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, Map<String, dynamic>>> getDashboardSummary(
    String userId,
    UserRole role,
  ) async {
    try {
      // Check cache first
      final cachedSummary = await _localDataSource.getCachedDashboardSummary(
        userId,
        role.value,
      );

      if (cachedSummary != null) {
        return Right({
          'summary': cachedSummary.summary,
          'quickStats': cachedSummary.quickStats,
          'keyMetrics': cachedSummary.keyMetrics,
          'lastCalculated': cachedSummary.lastCalculated.toIso8601String(),
        });
      }

      // Fetch from remote
      final remoteSummary = await _remoteDataSource.getDashboardSummary(
        userId,
        role.value,
      );

      // Cache the summary
      await _localDataSource.cacheDashboardSummary(
        userId,
        role.value,
        remoteSummary,
      );

      return Right({
        'summary': remoteSummary.summary,
        'quickStats': remoteSummary.quickStats,
        'keyMetrics': remoteSummary.keyMetrics,
        'lastCalculated': remoteSummary.lastCalculated.toIso8601String(),
      });
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get dashboard summary: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, Map<String, List<dynamic>>>>
  getDashboardTrends(
    String userId,
    UserRole role,
    DateTime startDate,
    DateTime endDate,
    String interval,
  ) async {
    try {
      // Check cache first
      final cachedTrends = await _localDataSource.getCachedDashboardTrends(
        userId,
        role.value,
      );

      if (cachedTrends != null) {
        return Right(cachedTrends);
      }

      // Fetch from remote
      final remoteTrends = await _remoteDataSource.getDashboardTrends(
        userId,
        role.value,
        startDate,
        endDate,
        interval,
      );

      // Cache the trends
      await _localDataSource.cacheDashboardTrends(
        userId,
        role.value,
        remoteTrends,
      );

      return Right(remoteTrends);
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get dashboard trends: ${e.toString()}',
        ),
      );
    }
  }

