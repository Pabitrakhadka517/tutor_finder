      return Right(hasMinimumData);
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to check minimum data requirement: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, void>> refreshDashboardCache(
    String userId,
    UserRole role,
  ) async {
    try {
      // Clear existing cache
      await _localDataSource.clearUserCache(userId, role.value);

      // Trigger backend aggregation refresh
      await _remoteDataSource.refreshDashboardAggregations(userId, role.value);

      // Fetch fresh data based on role
      if (role == UserRole.student) {
        await getStudentDashboard(userId);
      } else {
        await getTutorDashboard(userId);
      }

      return const Right(null);
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to refresh dashboard cache: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, void>> clearDashboardCache(
    String userId,
    UserRole role,
  ) async {
    try {
      await _localDataSource.clearUserCache(userId, role.value);
      return const Right(null);
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to clear dashboard cache: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, void>> clearAllDashboardCache() async {
    try {
      await _localDataSource.clearAllCache();
      return const Right(null);
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to clear all dashboard cache: ${e.toString()}',
        ),
      );
    }
  }

  @override
  Future<Either<DashboardFailure, Map<String, dynamic>>>
  getDashboardCacheStatus(String userId, UserRole role) async {
    try {
      final cacheStatus = await _localDataSource.getCacheStatus(
        userId,
        role.value,
      );

      if (cacheStatus == null) {
        return Right({
          'exists': false,
          'userId': userId,
          'role': role.value,
          'message': 'No cache found for user',
        });
      }

      return Right(cacheStatus.getStatistics());
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get cache status: ${e.toString()}',
        ),
      );
    }
  }

  // Private helper methods

  DashboardFailure _mapDataSourceExceptionToFailure(
    DashboardDataSourceException exception,
  ) {
    if (exception.isNetworkError) {
      return DashboardFailure.connectionError(exception.message);
    }

    if (exception.isAuthError) {
      return DashboardFailure.permissionDenied(exception.message);
    }

    if (exception.isServerError) {
      return DashboardFailure.serverError(exception.message);
    }

    if (exception.isRateLimit) {
      return DashboardFailure.rateLimited(exception.message);
    }

    if (exception.statusCode == 404) {
      return DashboardFailure.dataNotFound(exception.message);
    }

    if (exception.statusCode == 400) {
      return DashboardFailure.validationError(exception.message);
    }

    return DashboardFailure.unexpected(exception.message);
  }
}
