    String userId,
    UserRole role,
    DateTime currentStart,
    DateTime currentEnd,
    DateTime previousStart,
    DateTime previousEnd,
  ) async {
    try {
      final comparison = await _remoteDataSource.getDashboardComparison(
        userId,
        role.value,
        currentStart,
        currentEnd,
        previousStart,
        previousEnd,
      );

      return Right(comparison);
    } on DashboardDataSourceException catch (e) {
      return Left(_mapDataSourceExceptionToFailure(e));
    } catch (e) {
      return Left(
        DashboardFailure.unexpected(
          'Failed to get dashboard comparison: ${e.toString()}',
        ),
      );
    }
  }

